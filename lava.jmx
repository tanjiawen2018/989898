              <stringProp name="script">import com.common.ReadExcelData;
import org.apache.poi.xssf.usermodel.XSSFSheet;
import org.apache.poi.xssf.usermodel.XSSFWorkbook;
import java.util.Iterator;
import java.util.Map;
public void test(){
	        	String sheetName = &quot;智能硬件APP接口信息&quot;;
			XSSFWorkbook xssfWorkbook=vars.getObject(&quot;xssfWorkbook&quot;);
			ReadExcelData readExcelData =vars.getObject(&quot;readExcelData&quot;);
			HashMap hashMap =vars.getObject(&quot;hashMap&quot;);
//			eachMap(hashMap);
        	 	Map map = readExcelData.getExcelData(xssfWorkbook, sheetName, 4,hashMap);
        	 	vars.putObject(&quot;map&quot;,map); 
//        	 	eachMap(map);
        		requestParameterValue(map);
}

public void eachMap(Map map){
        		Iterator it = map.entrySet().iterator();
        		while (it.hasNext()) {
            		Map.Entry entry = (Map.Entry) it.next();
                	String key = String.valueOf(entry.getKey());
                	String value = String.valueOf(entry.getValue());
           		log.info(entry.getKey() + &quot;:&quot; + entry.getValue());
        	} 
}

public void requestParameterValue(Map map){
	vars.put(&quot;actualResultField&quot;,map.get(&quot;actualResultField&quot;).toString());
	vars.put(&quot;brief[1]&quot;,map.get(&quot;brief[1]&quot;).toString());
	vars.put(&quot;add_size&quot;,map.get(&quot;add_size&quot;).toString());
