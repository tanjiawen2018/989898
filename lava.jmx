	vars.put(&quot;contentType&quot;,map.get(&quot;contentType&quot;).toString());
	vars.put(&quot;app_id&quot;,map.get(&quot;app_id&quot;).toString());
	vars.put(&quot;name[1]&quot;,map.get(&quot;name[1]&quot;).toString());
	vars.put(&quot;isExecute&quot;,map.get(&quot;isExecute&quot;).toString());
	vars.put(&quot;lineNumbers&quot;,map.get(&quot;lineNumbers&quot;).toString());
	vars.put(&quot;method&quot;,map.get(&quot;method&quot;).toString());
	vars.put(&quot;max_system&quot;,map.get(&quot;max_system&quot;).toString());
	vars.put(&quot;ip&quot;,map.get(&quot;ip&quot;).toString());
