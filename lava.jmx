	vars.put(&quot;cover&quot;,map.get(&quot;cover&quot;).toString());
	vars.put(&quot;path&quot;,map.get(&quot;path&quot;).toString());
	vars.put(&quot;protocol&quot;,map.get(&quot;protocol&quot;).toString());
	vars.put(&quot;full_download_url&quot;,map.get(&quot;full_download_url&quot;).toString());
	vars.put(&quot;detail[1]&quot;,map.get(&quot;detail[1]&quot;).toString());
	vars.put(&quot;min_system&quot;,map.get(&quot;min_system&quot;).toString());
